# ============================================================
# Prophet Strategies — Engine Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Polymarket API credentials (from app.polymarket.com)
# ----------------------------------------------------------
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# Polygon wallet private key (hex, without 0x prefix)
# Required for live order signing; not used in paper trading.
PRIVATE_KEY=

# Polygon chain ID: 137 = mainnet, 80001 = Mumbai testnet
CHAIN_ID=137

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://prophet:prophet@localhost/prophet

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------
# REST API
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Bearer token used by the dashboard to authenticate.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=change_me_to_a_random_secret_token

# Comma-separated allowed CORS origins for the dashboard.
# Example: https://prophet-dashboard.vercel.app,http://localhost:3000
CORS_ORIGINS=["https://prophet-dashboard.vercel.app","http://localhost:3000"]

# ----------------------------------------------------------
# Risk Limits
# ----------------------------------------------------------
MAX_POSITION_PER_MARKET=100.0
MAX_DAILY_LOSS=200.0
MAX_OPEN_POSITIONS=20
MAX_CONCENTRATION=0.25
MAX_DRAWDOWN_TOTAL=0.30

# Kill switch — set to true to halt all trading immediately
KILL_SWITCH=false

# ----------------------------------------------------------
# Trading Mode
# *** MUST remain true until 8+ weeks of paper validation ***
# ----------------------------------------------------------
PAPER_TRADING=true

# ----------------------------------------------------------
# Scanner
# ----------------------------------------------------------
SCAN_INTERVAL_MINUTES=15
TARGET_CRYPTOS=["BTC","ETH","SOL"]

# ----------------------------------------------------------
# Telegram Notifications
# ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------
# LLM Pre-Trade Filter (optional)
# ----------------------------------------------------------
LLM_FILTER_ENABLED=false
ANTHROPIC_API_KEY=
LLM_FILTER_MODEL=claude-haiku-4-5-20251001
LLM_FILTER_MIN_CONFIDENCE=0.6
